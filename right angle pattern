import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        
    int i,j,n;
    Scanner s= new Scanner (System.in);
    n= s.nextInt();
    for(i=n;i>=1;i--){
        for(j=i;j>=1;j--){
            System.out.print("*");
            
        }
        System.out.println();
    }}
}
