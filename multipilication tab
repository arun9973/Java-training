import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
      int n,i,tab;
        Scanner s= new Scanner(System.in);
        n=s.nextInt();
        i=1;
        tab=0;
        for(i=1;i<=10;i++){
         tab=i*n;
            System.out.println(i+""+'*'+n+"="+tab);
            
        }
    }
}
