import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
      int n, digit,reverse;
        Scanner s= new Scanner (System.in);
        n= s.nextInt();
        reverse=0;
        while(n>0)
        {
            digit=n%10;
            reverse=reverse*10+digit;
            n=n/10;
        }
        if(n==reverse)
        { System.out.println("Palindrome");
            }
        else{
            System.out.println("Not Palindrome");
        }
    }
}
