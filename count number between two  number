        int n,i,count;
        Scanner s= new Scanner (System.in);
        count=0;
        n=s.nextInt();
        i=s.nextInt();
        for(int j=i;j<=n;j++){
           if(j<=n){
            count++;
        }
       
    }  System.out.println(count);}}
