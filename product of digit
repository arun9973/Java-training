import java.util.*;
 public class digit{
    public static void main(String [] args){
        int n,digit,m;
        Scanner s= new Scanner( System.in);
        n=s.nextInt();
        digit=1;
        while (n>0){
            m=n%10;
            digit=digit*m;
            n=n/10;

        }
        System.out.println(digit);
        
    } 
     
 }
