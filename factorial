import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int a,fact;
        Scanner s= new Scanner(System.in);
        a=s.nextInt();
        fact=1;
        for(int i=1;i<=a;i++)
        {
            fact=fact*i;
           
        }
        System.out.println(fact);
         }
}
